import example.*

describe "tito" {

  test "rendimiento de tito inicial" {
    assert.equals(1,tito.rendimiento())
  }
    test "rendimiento de tito si toma 15 terere" {
    tito.consumir(15,terere)
    assert.equals(1.5,tito.rendimiento())
  }
   test "velocidad de tito si toma 15 terere" {
    tito.consumir(15,terere)
    assert.equals(10.5,tito.velocidad())
  }
}
